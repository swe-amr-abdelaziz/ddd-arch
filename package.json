{
  "name": "ddd-arch",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.2",
  "description": "Deterministic DDD + clean architecture conventions for TypeScript backends, enforced by ESLint.",
  "license": "MIT",
  "author": "Amr Abdelaziz (https://github.com/swe-amr-abdelaziz)",
  "repository": {
    "type": "git",
    "url": "https://github.com/swe-amr-abdelaziz/ddd-arch.git"
  },
  "scripts": {
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish",
    "prepare": "husky",
    "typecheck": "tsc",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "doc:check": "pnpm -C packages/eslint-plugin doc:check",
    "spell": "cspell --no-progress --dot \"**/*.{md,mjs,js,cjs,json,yml,yaml}\"",
    "knip": "knip",
    "check:parity": "node scripts/check-parity.mjs",
    "check:adr-numbering": "node scripts/check-adr-numbering.mjs",
    "check:adr-on-feat": "node scripts/check-adr-on-feat.mjs"
  },
  "adr": {
    "requireOn": [
      "feat"
    ]
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@ddd-arch/eslint-plugin": "workspace:*",
    "cspell": "^10.0.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-eslint-plugin": "^7.4.0",
    "eslint-plugin-import-x": "^4.17.0",
    "husky": "^9.1.7",
    "knip": "^6.21.0",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.5",
    "typescript": "^6.0.3"
  }
}

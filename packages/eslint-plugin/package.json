{
  "name": "@ddd-arch/eslint-plugin",
  "version": "0.2.0",
  "description": "Deterministic DDD + clean architecture ESLint rules for TypeScript backends.",
  "keywords": [
    "eslint",
    "eslint-plugin",
    "ddd",
    "domain-driven-design",
    "clean-architecture",
    "hexagonal",
    "nestjs",
    "adr",
    "architecture"
  ],
  "type": "module",
  "license": "MIT",
  "author": "Amr Abdelaziz (https://github.com/swe-amr-abdelaziz)",
  "repository": {
    "type": "git",
    "url": "https://github.com/swe-amr-abdelaziz/ddd-arch.git",
    "directory": "packages/eslint-plugin"
  },
  "homepage": "https://github.com/swe-amr-abdelaziz/ddd-arch/tree/main/packages/eslint-plugin#readme",
  "bugs": "https://github.com/swe-amr-abdelaziz/ddd-arch/issues",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "pnpm build",
    "doc": "eslint-doc-generator",
    "doc:check": "eslint-doc-generator --check"
  },
  "dependencies": {
    "@eslint/markdown": "^8.0.2",
    "@typescript-eslint/utils": "^8.62.1"
  },
  "peerDependencies": {
    "eslint": "^9.6.0 || ^10.0.0"
  },
  "devDependencies": {
    "@typescript-eslint/rule-tester": "^8.62.1",
    "eslint": "^10.5.0",
    "eslint-doc-generator": "^3.6.0",
    "prettier": "^3.8.5",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
